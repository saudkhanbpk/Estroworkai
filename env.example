# ===========================================
# ESTRO AI - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp env.example .env

# ===========================================
# General Settings
# ===========================================
NODE_ENV=production
# For EC2: use 'production'
# For local development: use 'development'

# ===========================================
# OpenAI Configuration (REQUIRED)
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ===========================================
# JWT Authentication
# ===========================================
# Generate a secure random string: openssl rand -hex 32
JWT_SECRET=your-super-secure-jwt-secret-change-this

# ===========================================
# MongoDB Configuration
# ===========================================
# Option 1: Use local MongoDB via Docker Compose (default)
MONGO_USER=admin
MONGO_PASSWORD=your-secure-mongo-password

# Option 2: Use MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/estro-ai?retryWrites=true&w=majority

# ===========================================
# Server Ports
# ===========================================
BACKEND_PORT=5000
FRONTEND_PORT=3000

# ===========================================
# Domain Configuration (for production)
# ===========================================
# Your EC2 public IP or domain name
DOMAIN=localhost
# Example: DOMAIN=estro-ai.yourdomain.com
# Example: DOMAIN=ec2-xx-xxx-xxx-xxx.compute-1.amazonaws.com

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://estro-ai.yourdomain.com

# ===========================================
# Docker Configuration
# ===========================================
# Base path for workspace files on host machine
WORKSPACE_BASE_PATH=/var/workspaces

# Docker socket path (usually no need to change)
DOCKER_SOCKET=/var/run/docker.sock

# ===========================================
# Redis Configuration (optional, for scaling)
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# SSL/TLS Configuration (production)
# ===========================================
# Set to 'true' to enable HTTPS via nginx
SSL_ENABLED=false
# Path to SSL certificate and key (if using SSL)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ===========================================
# Resource Limits
# ===========================================
# Maximum memory per workspace container (in bytes)
CONTAINER_MEMORY_LIMIT=536870912
# 512MB = 536870912, 1GB = 1073741824

# Maximum number of concurrent workspaces per user
MAX_WORKSPACES_PER_USER=5

# ===========================================
# NPM Install Configuration
# ===========================================
# Timeout for npm install commands (in milliseconds)
# Default: 300000 (5 minutes)
NPM_INSTALL_TIMEOUT=300000

# Maximum number of retries for npm install if it times out
# Default: 2
NPM_INSTALL_MAX_RETRIES=2
